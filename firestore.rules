rules_version='2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check for internal API key
    function isInternalAgent() {
      return request.headers['x-api-key'] == 'acb66b54c1b0db79aabc64a9c8e5c9652763a62efea7c246ca96d006b0e28344';
    }

    // Leads — readable by internal agents, writable only by internal agents
    match /leads/{leadId} {
      allow read: if true;
      allow write: if isInternalAgent();
    }

    // Companies
    match /companies/{companyId} {
      allow read: if true;
      allow write: if isInternalAgent();
    }

    // Deals
    match /deals/{dealId} {
      allow read: if true;
      allow write: if isInternalAgent();
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if true;
      allow write: if isInternalAgent();
    }

    // Activities
    match /activities/{activityId} {
      allow read: if true;
      allow write: if isInternalAgent();
    }

    // Chroma shared context — full access to internal agents
    match /agents/chroma/{document=**} {
      allow read, write: if isInternalAgent();
    }

    // Agent runs
    match /agentRuns/{runId} {
      allow read, write: if true;
    }
  }
}
